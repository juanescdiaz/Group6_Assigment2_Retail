    "processing_time_sum = processing_time_sum.merge(order_counts[['Ship Mode', 'Unique Order Count']], on='Ship Mode')\n",
    "processing_time_sum['Average Processing Time'] = round(processing_time_sum['Total Processing Time'] / processing_time_sum['Unique Order Count'], 2)\n",
